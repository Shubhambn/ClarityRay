{
  "id": "efficientnetb0-pediatric-chest",
  "name": "EfficientNet-B0 Pediatric Chest X-ray Screening Model",
  "version": "0.1.0",
  "certified": false,
  "bodypart": "chest",
  "modality": "xray",
  "model": {
    "file": "/models/efficientnetb0-pediatric-chest/model.onnx",
    "format": "onnx"
  },
  "input": {
    "shape": [1, 3, 320, 320],
    "layout": "NCHW",
    "normalize": {
      "mean": [0.5, 0.5, 0.5],
      "std": [0.5, 0.5, 0.5]
    }
  },
  "output": {
    "shape": [1, 2],
    "classes": ["No Finding", "Possible Pneumonia Finding"],
    "activation": "softmax"
  },
  "safety": {
    "tier": "research",
    "disclaimer": "Research-use screening output only. A possible finding detected result may suggest abnormality and should be reviewed by a clinician. A no finding detected result does not exclude disease."
  },
  "thresholds": {
    "possible_finding": 0.5,
    "low_confidence": 0.25,
    "validation_status": "unvalidated"
  }
}
