{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://clarityray.dev/schemas/clarity-schema.json",
  "title": "ClarityRay Model Specification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "version",
    "certified",
    "model",
    "input",
    "output",
    "safety",
    "bodypart",
    "modality"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "certified": {
      "type": "boolean",
      "const": false
    },
    "bodypart": {
      "type": "string",
      "minLength": 1
    },
    "modality": {
      "type": "string",
      "minLength": 1
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file"],
      "properties": {
        "file": {
          "type": "string",
          "minLength": 1
        },
        "format": {
          "type": "string"
        }
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shape", "normalize"],
      "properties": {
        "shape": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "layout": {
          "type": "string"
        },
        "normalize": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mean", "std"],
          "properties": {
            "mean": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "number"
              }
            },
            "std": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "number"
              }
            }
          }
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classes", "activation"],
      "properties": {
        "shape": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "activation": {
          "type": "string",
          "enum": ["softmax", "sigmoid", "none"]
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tier", "disclaimer"],
      "properties": {
        "tier": {
          "type": "string",
          "enum": ["screening", "research", "investigational"]
        },
        "disclaimer": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["possible_finding", "low_confidence", "validation_status"],
      "properties": {
        "possible_finding": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "low_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "validation_status": {
          "type": "string",
          "enum": ["unvalidated", "validated"]
        }
      }
    }
  }
}
